# ══════════════════════════════════════════════════════════════════════════════
# AdsPulse — Client Environment Variables
# Copy this file to client/.env.local
# ══════════════════════════════════════════════════════════════════════════════

# ── API URL ───────────────────────────────────────────────────────────────────
# Leave empty for development (uses proxy from package.json → localhost:5000)
# Set for production: REACT_APP_API_URL=https://api.yourdomain.com
REACT_APP_API_URL=

# ── Stripe Publishable Key ────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use pk_test_... for testing, pk_live_... for production
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key

# ── Fix for react-scripts allowedHosts error ─────────────────────────────────
# Uncomment the line below if you get:
# "options.allowedHosts[0] should be a non-empty string"
# DANGEROUSLY_DISABLE_HOST_CHECK=true

# ══════════════════════════════════════════════════════════════════════════════
# PRODUCTION VALUES (change before deploying)
# ══════════════════════════════════════════════════════════════════════════════
# REACT_APP_API_URL=https://api.yourdomain.com

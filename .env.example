# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/ads_manager

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=adspulse_dev_secret_change_in_production
JWT_2FA_SECRET=adspulse_2fa_secret_change_in_production
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000
PORT=5000

# ── Email (2FA + team invitations) ───────────────────────────────────────────
# Without these, codes print to server terminal (dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password

# ── META (Facebook & Instagram) ──────────────────────────────────────────────
# Get from: https://developers.facebook.com/apps/
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# Redirect URI to add in Meta App → Facebook Login → Valid OAuth Redirect URIs:
# http://localhost:5000/api/oauth/meta/callback

# ── GOOGLE ADS + YOUTUBE ─────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth2 credentials → Web Application
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Get developer token from: https://ads.google.com/aw/apicenter
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
# Redirect URI to add in Google Cloud Console → Authorized redirect URIs:
# http://localhost:5000/api/oauth/google/callback

# ── TIKTOK FOR BUSINESS ───────────────────────────────────────────────────────
# Get from: https://business-api.tiktok.com/portal/apps
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
# Redirect URI to add in TikTok App → Redirect URI:
# http://localhost:5000/api/oauth/tiktok/callback

# ── LINKEDIN ─────────────────────────────────────────────────────────────────
# Get from: https://www.linkedin.com/developers/apps/
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
# Redirect URI to add in LinkedIn App → Auth → Authorized redirect URLs:
# http://localhost:5000/api/oauth/linkedin/callback

# ── TWITTER / X ──────────────────────────────────────────────────────────────
# Get from: https://developer.twitter.com/en/portal/dashboard
# Requires Elevated access + Ads API approval
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
# Redirect URI to add in Twitter App → User authentication settings:
# http://localhost:5000/api/oauth/twitter/callback

# ── SNAPCHAT ─────────────────────────────────────────────────────────────────
# Get from: https://developers.snap.com/
# Requires Snapchat Marketing API access approval
SNAPCHAT_CLIENT_ID=your_snapchat_client_id
SNAPCHAT_CLIENT_SECRET=your_snapchat_client_secret
# Redirect URI to add in Snapchat App → Redirect URIs:
# http://localhost:5000/api/oauth/snapchat/callback

# ── Stripe (production billing only) ─────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...


# ── Cloud Storage (Cloudinary) ───────────────────────────────

# ── Database ──────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/ads_manager

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=adspulse_dev_secret_2024
JWT_2FA_SECRET=adspulse_2fa_temp_secret_2024
CLIENT_URL=http://localhost:3000
PORT=5000

# ── Email (for 2FA email OTP) ─────────────────────────────────
# Use Gmail: enable "App Passwords" in Google Account settings
# then use your Gmail address and the App Password (not your login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here

# ── Platform API Keys (optional — only needed for real sync) ──
# These are filled in via the Integrations page in the app
# and stored per-user in MongoDB. You don't need them here.
